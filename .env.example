MONGODB_URI=your_mongodb_connection_string
PORT=3001
# For local testing, force Stripe/email redirects to localhost frontend
FORCE_LOCAL_FRONTEND=true
FRONTEND_URL_LOCAL=http://localhost:5173/
FRONTEND_URL_DEPLOYED=https://www.kanridesign.com/
FRONTEND_URL_DEPLOYED_NO_WWW=https://kanridesign.com/
# Legacy fallback vars (optional)
FRONTEND_URL=https://www.kanridesign.com/
FRONTEND_URL_NO_WWW=https://kanridesign.com/
# Public backend base URL used when generating masked delivery links in status notes
BACKEND_PUBLIC_URL=https://backend-kappa-khaki-71.vercel.app
# Optional preferred variable for delivery links (overrides BACKEND_PUBLIC_URL)
DELIVERY_PUBLIC_URL=https://backend-kappa-khaki-71.vercel.app
JWT_SECRET=your-jwt-secret

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM_CLIENT=your_client_from_email
EMAIL_FROM_COLLABORATOR=your_collaborator_from_email
EMAIL_FROM_ADMIN=your_admin_from_email

HOLDED_API_KEY=your_holded_api_key
